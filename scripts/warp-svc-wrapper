#!/bin/sh
set -eu

: "${WARP_PROXY_RUN_DIR:=/run/warp-proxy}"
: "${WARP_PROXY_STATUS_DIR:=$WARP_PROXY_RUN_DIR/status}"

STATUS_FILE=$WARP_PROXY_STATUS_DIR/warp-svc

record_exit_status() {
  status=$?
  mkdir -p "$WARP_PROXY_STATUS_DIR"
  printf '%s\n' "$status" > "$STATUS_FILE"
}

trap record_exit_status EXIT

warp_svc_bin=$(command -v warp-svc)
warp_svc_pid=

stop_warp_svc() {
  trap - INT TERM

  echo "Disconnecting WARP before stopping warp-svc..."
  warp-cli --accept-tos disconnect >/dev/null 2>&1 || true

  if [ -n "$warp_svc_pid" ] && kill -0 "$warp_svc_pid" 2>/dev/null; then
    kill -TERM "$warp_svc_pid" 2>/dev/null || true
    wait "$warp_svc_pid" 2>/dev/null || true
  fi

  exit 0
}

trap stop_warp_svc INT TERM

"$warp_svc_bin" &
warp_svc_pid=$!

set +e
wait "$warp_svc_pid"
status=$?
set -e

exit "$status"
